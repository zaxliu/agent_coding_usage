# Identity
# Required: set your group username, e.g. san.zhang
ORG_USERNAME=
HASH_SALT=replace_with_team_secret_salt
TIMEZONE=Asia/Shanghai
LOOKBACK_DAYS=7

# Feishu Bitable
FEISHU_APP_TOKEN=
# Optional: if empty, sync will auto-select the first table under FEISHU_APP_TOKEN.
FEISHU_TABLE_ID=
FEISHU_APP_ID=
FEISHU_APP_SECRET=
# Optional override. If empty, runtime fetches tenant_access_token via APP_ID/APP_SECRET.
FEISHU_BOT_TOKEN=

# Optional source path overrides (comma-separated globs)
CLAUDE_LOG_PATHS=
CODEX_LOG_PATHS=
CURSOR_LOG_PATHS=
